{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 24, "patch": 0 },

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },

    {
      "name": "release",
      "displayName": "Release",
      "description": "Optimised build: -O3 -march=native + LTO. Requires GCC or Clang.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "release-pext",
      "displayName": "Release + PEXT",
      "description": "Like release, plus BMI2 PEXT sliding-piece attacks (Haswell+ / Zen 3+).",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "USE_PEXT": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Unoptimised debug build with AddressSanitizer and UBSan (GCC/Clang only).",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SANITIZE": "ON"
      }
    },
    {
      "name": "relwithdebinfo",
      "displayName": "Release with Debug Info",
      "description": "Optimised build with debug symbols, no sanitizers.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    }
  ],

  "buildPresets": [
    { "name": "release",        "configurePreset": "release" },
    { "name": "release-pext",   "configurePreset": "release-pext" },
    { "name": "debug",          "configurePreset": "debug" },
    { "name": "relwithdebinfo", "configurePreset": "relwithdebinfo" }
  ]
}
