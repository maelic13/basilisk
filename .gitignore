.idea/
.vs/
.vscode/
build/
cmake-build*
debug/
release/
x64/

# Machine-local CMake toolchain overrides (see CMakeUserPresets.json.example)
CMakeUserPresets.json

# CMake artifacts (generated if cmake is run in the source tree)
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
compile_commands.json
Testing/
_deps/

# Compiler / linker output artifacts
*.obj
*.pdb
*.ilk
*.exp

# Diagnostic / test artifacts
*.pgn
config.json
calibration_*.txt
diag*.txt
loop_diag.txt
test_input.txt
test_output*.txt

.zed/

# Tuning toolchain — downloaded/cloned externals and built test binaries
tools/bin/*
tools/weather-factory/
tools/test_engines/*.exe
tools/results/*
# Keep .gitkeep sentinels so empty dirs survive git clone
!tools/bin/.gitkeep
!tools/test_engines/.gitkeep
!tools/results/.gitkeep

# Opening book committed to the repo (override the *.pgn rule above)
!tools/books/
!tools/books/SuperGM_4mvs.pgn
