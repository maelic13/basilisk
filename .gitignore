.idea/
.vs/
.vscode/
.cache/
.clangd/
build/
cmake-build*
debug/
release/
x64/

# Machine-local CMake toolchain overrides (see CMakeUserPresets.json.example)
CMakeUserPresets.json

# CMake artifacts (generated if cmake is run in the source tree)
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
compile_commands.json
DartConfiguration.tcl
install_manifest.txt
CMakeScratch/
Testing/
_deps/

# Ninja artifacts
.ninja_deps
.ninja_log
build.ninja
rules.ninja

# Compiler / linker output artifacts
*.o
*.obj
*.d
*.a
*.lib
*.dll
*.so
*.dylib
*.exe
*.pdb
*.ilk
*.exp
*.map

# Profile-guided optimization / coverage artifacts
*.profraw
*.profdata
*.gcda
*.gcno
*.gcov

# Diagnostic / test artifacts
*.log
*.tmp
*.pgn
config.json
calibration_*.txt
diag*.txt
loop_diag.txt
test_input.txt
test_output*.txt

.zed/
__pycache__/
*.pyc
.DS_Store

# Tuning toolchain — downloaded/cloned externals and built test binaries
tools/bin/*
tools/weather-factory/
tools/test_engines/*.exe
tools/results/*
# Keep .gitkeep sentinels so empty dirs survive git clone
!tools/bin/.gitkeep
!tools/test_engines/.gitkeep
!tools/results/.gitkeep

# Texel generated datasets / round-trip dumps
tools/texel/data/*
tools/texel/out/
tools/texel/dump*.txt

# Opening books are local test/tuning inputs.
!tools/books/
!tools/books/.gitkeep
